<config version="10.1.0">
  <devices>
    <entry name="localhost.localdomain">
      <hostname>CORP-PA-FW01</hostname>
      <network>
        <interface>
          <ethernet>
            <entry name="ethernet1/1">
              <layer3>
                <ip><entry name="203.0.113.2/24"/></ip>
              </layer3>
              <comment>WAN Interface</comment>
            </entry>
            <entry name="ethernet1/2">
              <layer3>
                <ip><entry name="10.0.2.1/24"/></ip>
              </layer3>
              <comment>LAN Interface</comment>
            </entry>
          </ethernet>
        </interface>
      </network>
      <security>
        <rules>
          <entry name="Allow-HTTPS-Inbound">
            <from><member>untrust</member></from>
            <to><member>trust</member></to>
            <application><member>ssl</member></application>
            <service><member>application-default</member></service>
            <action>allow</action>
            <log-end>yes</log-end>
          </entry>
          <entry name="Block-Telnet">
            <from><member>any</member></from>
            <to><member>any</member></to>
            <application><member>telnet</member></application>
            <action>deny</action>
            <log-end>yes</log-end>
          </entry>
          <entry name="Deny-All">
            <from><member>any</member></from>
            <to><member>any</member></to>
            <application><member>any</member></application>
            <action>deny</action>
            <log-end>yes</log-end>
          </entry>
        </rules>
      </security>
    </entry>
  </devices>
</config>
